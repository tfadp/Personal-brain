NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
ANTHROPIC_API_KEY=your-anthropic-api-key
SUPADATA_API_KEY=your-supadata-key

# OpenAI for contact embeddings (semantic pre-filter on contact search)
OPENAI_API_KEY=your-openai-api-key

# Gmail newsletter sync (see setup instructions in HANDOFF.md)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# Google Calendar sync — separate refresh token with calendar.readonly scope
# Get one by running: npm run auth:gcal
GCAL_REFRESH_TOKEN=your-gcal-refresh-token
